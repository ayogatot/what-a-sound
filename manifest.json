{
  "manifest_version": 3,
  "name": "What a Sound",
  "version": "1.0",
  "description": "Plays meme sound effects triggered by copy, paste, and text selection.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "What a Sound Settings",
    "default_popup": "src/options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/sounds/*.mp3",
        "assets/sounds/*.wav"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}